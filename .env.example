# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
#
# Multi-environment setup:
#   Copy .env.example to .env for base config, then create a profile-specific
#   override file (e.g. .env.work) with only the values that differ.
#   Set ENV_PROFILE=work to load .env.work on top of .env automatically.
#
# ENV_PROFILE=work    # optional — loads .env.work as override


# ── Claude API ──────────────────────────────────────────────────────────────
# Required for Research Chat, News Digest, Investment Search, and other cloud agents.
# Obtain your API key at console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# ── Tavily Search (optional) ─────────────────────────────────────────────────
# When set, Tavily replaces Anthropic's built-in web_search for all agents.
# Useful if your Anthropic setup does not include web search access.
# Free tier: 1000 searches/month — https://tavily.com
# TAVILY_API_KEY=your_tavily_api_key_here


# ── Ollama (local LLM) ──────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2


# ── Encryption ──────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_encryption_key_here


# ── App Authentication (optional) ────────────────────────────────────────────
# Optional password to restrict app access. Leave empty to disable login.
# Works seamlessly with Apple Passwords / macOS Keychain for autofill.
# APP_PASSWORD=


# ── Portfolio Storage ───────────────────────────────────────────────────────
DB_PATH=data/portfolio.db


# ── Demo Mode ───────────────────────────────────────────────────────────────
# DEMO_MODE=true
# DEMO_DB_PATH=data/demo.db


# ── Market Data ─────────────────────────────────────────────────────────────
# MARKET_DATA_FETCH_HOUR=18   # hour (0-23) for automatic price refresh
# RATE_LIMIT_RPS=2.0          # yfinance requests per second


# ── Logging ─────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO              # DEBUG, INFO, WARNING, ERROR, CRITICAL


# ── Currency ────────────────────────────────────────────────────────────────
# BASE_CURRENCY=EUR           # EUR (default), CHF, GBP, USD, JPY


# ── Backup ───────────────────────────────────────────────────────────────────
# Path to your restic repository on an external drive.
# Run manually: /Users/<you>/scripts/wm_backup.sh
# Setup: brew install restic → restic init -r $BACKUP_REPO_PATH
BACKUP_REPO_PATH=/Volumes/YOUR_DRIVE_NAME/restic-repo
RESTIC_PASSWORD_FILE=/Users/<you>/.restic_password
