# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains your API keys and encryption keys.
#
# This is a public repository. Be extra careful:
# - Never push your .env file
# - Rotate any leaked API keys immediately
# - Use separate API keys for staging/testing vs. production
#
# Multi-environment setup (optional):
#   Copy .env.example to .env for base config, then create a profile-specific
#   override file (e.g. .env.work) with only the values that differ.
#   Set ENV_PROFILE=work to load .env.work on top of .env automatically.
#
# ENV_PROFILE=work    # optional — loads .env.work as override


# ── Public LLM (Cloud Agents) ──────────────────────────────────────────────
# Default: Anthropic Claude. Can be switched to any compatible provider below.
# Set LLM_API_KEY to your API key and optionally LLM_BASE_URL for custom endpoints.

# Option A: Anthropic Claude (default)
# Obtain your API key at console.anthropic.com
# For backward compatibility, ANTHROPIC_API_KEY is also supported.
LLM_API_KEY=your_anthropic_api_key_here
# LLM_BASE_URL=                              # leave empty for Anthropic direct
# LLM_DEFAULT_MODEL=claude-haiku-4-5-20251001  # optional model override

# Option B: OpenRouter (supports 100+ models: Claude, GPT-4o, Perplexity, etc.)
# Obtain your API key at https://openrouter.ai
# LLM_API_KEY=sk-or-...
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_DEFAULT_MODEL=anthropic/claude-sonnet-4-6
# CLAUDE_MODELS=anthropic/claude-haiku-4-5-20251001,anthropic/claude-sonnet-4-6,anthropic/claude-opus-4-6

# ── OpenAI-Compatible Provider (optional) ───────────────────────────────────
# Use this to switch ALL cloud agents to an OpenAI-format API (Perplexity Sonar, Groq, Together, etc.)
# When OPENAI_BASE_URL is set, cloud agents automatically use OpenAI provider instead of Claude.

# Option C: Perplexity Sonar (fast, cheap, has built-in web search)
# Obtain your API key at https://www.perplexity.ai/api
# OPENAI_API_KEY=pplx-...
# OPENAI_BASE_URL=https://api.perplexity.ai
# OPENAI_MODELS=sonar,sonar-pro,sonar-reasoning
# LLM_DEFAULT_MODEL=sonar                  # optional, picked from OPENAI_MODELS

# Option D: Groq (fastest inference, cost-effective)
# Obtain your API key at https://console.groq.com
# OPENAI_API_KEY=gsk_...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODELS=mixtral-8x7b-32768,gemma-7b-it,llama2-70b-4096

# Option E: Together AI
# Obtain your API key at https://www.together.ai/
# OPENAI_API_KEY=your_together_api_key
# OPENAI_BASE_URL=https://api.together.xyz/v1
# OPENAI_MODELS=meta-llama/Llama-3-70b-chat-hf,mistralai/Mixtral-8x7B-Instruct-v0.1

# ── Tavily Search (optional) ─────────────────────────────────────────────────
# When set, Tavily replaces built-in web_search for all agents.
# Useful if your cloud provider doesn't include web search access (e.g. local Ollama).
# Free tier: 1000 searches/month — https://tavily.com
# TAVILY_API_KEY=your_tavily_api_key_here


# ── Ollama (local LLM) ──────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2


# ── Encryption ──────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_encryption_key_here


# ── App Authentication (optional) ────────────────────────────────────────────
# Optional password to restrict app access. Leave empty to disable login.
# Works seamlessly with Apple Passwords / macOS Keychain for autofill.
# APP_PASSWORD=


# ── Portfolio Storage ───────────────────────────────────────────────────────
DB_PATH=data/portfolio.db


# ── Demo Mode ───────────────────────────────────────────────────────────────
# DEMO_MODE=true
# DEMO_DB_PATH=data/demo.db


# ── Market Data ─────────────────────────────────────────────────────────────
# MARKET_DATA_FETCH_HOUR=18   # hour (0-23) for automatic price refresh
# RATE_LIMIT_RPS=2.0          # yfinance requests per second


# ── Logging ─────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO              # DEBUG, INFO, WARNING, ERROR, CRITICAL


# ── Currency ────────────────────────────────────────────────────────────────
# BASE_CURRENCY=EUR           # EUR (default), CHF, GBP, USD, JPY


# ── Backup ───────────────────────────────────────────────────────────────────
# Path to your restic repository on an external drive.
# Run manually: /Users/<you>/scripts/wm_backup.sh
# Setup: brew install restic → restic init -r $BACKUP_REPO_PATH
BACKUP_REPO_PATH=/Volumes/YOUR_DRIVE_NAME/restic-repo
RESTIC_PASSWORD_FILE=/Users/<you>/.restic_password
